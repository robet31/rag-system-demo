# OpenRouter API Configuration
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Redirect URL for OAuth (use your production URL)
NEXT_PUBLIC_REDIRECT_URL=https://your-project.vercel.app/auth/callback

# You can get your API key from https://openrouter.ai/settings/keys
# For demo purposes, it's already set in the code, but for production use:
# OPENROUTER_API_KEY=your-actual-api-key