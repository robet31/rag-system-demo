# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Redirect URL for OAuth (must match Supabase dashboard settings)
NEXT_PUBLIC_REDIRECT_URL=https://your-project.vercel.app/auth/callback

# OpenRouter API Configuration
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# You can get your API key from https://openrouter.ai/settings/keys

# Telegram Daily Digest Configuration
# Create a bot via @BotFather on Telegram to get the token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Get your chat/user ID via @userinfobot on Telegram
TELEGRAM_CHAT_ID=your-telegram-chat-id
# A random secret string to secure the cron endpoint (e.g. openssl rand -hex 32)
CRON_SECRET=your-random-cron-secret